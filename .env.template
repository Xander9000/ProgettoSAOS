# ===========================================
# Environment Variables - Template
# ===========================================
# Copia questo file in .env e sostituisci i valori placeholder
# NON committare .env nel repository - è già in .gitignore
# ===========================================

# PostgreSQL - Sostituisci con password forte
POSTGRES_PASSWORD=change-me-use-secure-random-string

# RabbitMQ - Sostituisci con credenziali forti
RABBITMQ_USER=admin
RABBITMQ_DEFAULT_PASS=change-me-use-secure-random-string

# JWT - RS256 asimmetrico: auth-service firma con privata, gli altri verificano con pubblica
# Generare con: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Poi: base64 private.pem (su Linux: cat private.pem | base64 -w0)
JWT_PRIVATE_KEY_B64=change-me-base64-encoded-private-key
JWT_PUBLIC_KEY_B64=change-me-base64-encoded-public-key

# Internal API Key - Per comunicazione sicura tra microservizi
INTERNAL_API_KEY=change-me-use-secure-random-string

# Mail - SMTP primario con fallback sendmail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="E-Learning Platform <noreply@example.com>"
SMTP_SECURE=false
SENDMAIL_PATH=/usr/sbin/sendmail
APP_PUBLIC_URL=http://localhost:8080

# Cookie secret - Per firmare i cookie HTTP (signed: true)
# Generare con: openssl rand -hex 32
COOKIE_SECRET=change-me-use-secure-random-64-char-hex-string

# Two-Factor Encryption - AES-256-GCM key per cifrare i secret 2FA a riposo
# Generare con: openssl rand -hex 32
TWO_FACTOR_ENCRYPTION_KEY=change-me-64-char-hex-string

# WebAuthn - Origin e RPID consentiti (separati da virgola)
ALLOWED_WEBAUTHN_ORIGINS=http://localhost:8080,http://localhost:3000
ALLOWED_RP_IDS=localhost
DEFAULT_RP_ID=localhost
